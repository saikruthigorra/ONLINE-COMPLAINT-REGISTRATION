NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/complaint_management
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:3000
AUTO_ASSIGN=true

# Optional SMTP settings for notifications
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Complaint Support <no-reply@complaints.local>"
